# Sequencer POC Configuration
# Copy to .env and modify as needed
# The Makefile automatically sources .env if present

# =============================================================================
# Execution Layer Selection
# =============================================================================

# Which execution layer to use: reth (default) or cdk-erigon
# - reth: Uses block-builder + op-reth with Engine API
#         Supports preconfirmations via WebSocket
#         Higher customization, external block building
# - cdk-erigon: Uses cdk-erigon as standalone sequencer
#               No preconfirmations (built-in sequencer)
#               Simpler setup, zkEVM-compatible
EXECUTION_LAYER=reth

# =============================================================================
# Block Production
# =============================================================================

# Block production interval in milliseconds
# Recommended: 1000 (1s) for development, 100-500 for high throughput
BLOCK_TIME_MS=1000

# Skip producing empty blocks (reduces noise in logs/dashboards)
SKIP_EMPTY_BLOCKS=true

# Block gas limit
# Common values:
#   150000000   = 150M (~7k simple txs)
#   500000000   = 500M (~24k simple txs)
#   1000000000  = 1B "gigagas" (~48k simple txs)
GAS_LIMIT=1000000000

# Maximum transactions per block (should scale with GAS_LIMIT)
# Rule of thumb: GAS_LIMIT / 21000 (simple tx gas)
MAX_TXS_PER_BLOCK=50000

# Transaction ordering (standard Ethereum txpool behavior)
#   fifo     - First-come, first-served
#   tip_desc - Highest tip first (default, standard Ethereum behavior)
#   tip_asc  - Lowest tip first
TX_ORDERING=tip_desc

# =============================================================================
# Preconfirmations
# =============================================================================

# Enable WebSocket preconfirmation streaming
# Provides real-time tx status updates (pending -> preconfirmed -> confirmed)
ENABLE_PRECONFIRMATIONS=true

# Preconfirmation WebSocket bind address
PRECONF_LISTEN_ADDR=:3001

# Event buffer size per client
PRECONF_BUFFER_SIZE=10000

# =============================================================================
# Transaction Pool
# =============================================================================

# Max times a tx can be requeued due to nonce gaps before being dropped
# Prevents infinite requeue loops when transactions have permanent nonce gaps
# Default: 50 (~50 blocks worth of retries)
MAX_REQUEUE_COUNT=50

# =============================================================================
# RPC Timeouts
# =============================================================================

# Timeout for nonce lookups (ms)
NONCE_TIMEOUT_MS=500

# =============================================================================
# Development Private Keys (DO NOT USE IN PRODUCTION)
# =============================================================================
#
# These are well-known Anvil test keys used for local development only.
# They are public and have no real value. NEVER use these keys with real funds.
#
# Anvil Account #0 - Used for contract deployment and test operations
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Anvil Account #1 - Used for Hyperlane bridge operations
HYP_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Anvil Account #0 - Used by polycli for load generation
POLYCLI_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# =============================================================================
# Usage
# =============================================================================
#
# Default: make run              - Uses these .env settings
# Profiles: make run-high-throughput, run-fast-confirm, etc.
# Override: BLOCK_TIME_MS=200 make run
#
