# WalletConnect Project ID - get one from https://cloud.walletconnect.com
# Required for wallet connections to work properly
NEXT_PUBLIC_WALLET_CONNECT_ID=your_project_id_here

# RPC overrides for local development (outside Docker)
# Inside Docker, these are configured via docker-compose environment
NEXT_PUBLIC_RPC_OVERRIDES={"l1local":{"http":"http://localhost:18545"},"l2local":{"http":"http://localhost:13000"}}
