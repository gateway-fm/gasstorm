# External L1 Configuration
# Copy to config/l1/<name>.env, then: make up L1=<name> PROFILE=reth WITH=explorer
#
# Example:
#   cp config/l1/example.env config/l1/dtcc-qa.env
#   # Edit dtcc-qa.env with your chain details
#   make up L1=dtcc-qa PROFILE=reth WITH=explorer,bridge

# Required: Full HTTP(S) RPC URL (credentials can be embedded)
EXTERNAL_L1_RPC=https://user:pass@your-l1-node:8545/

# Optional: WebSocket URL for subscriptions
# EXTERNAL_L1_WS=wss://user:pass@your-l1-node:8546/

# Optional: Chain ID (auto-detected from RPC if omitted)
# EXTERNAL_L1_CHAIN_ID=

# Optional: Chain name for Hyperlane registry (defaults to L1= value)
# NOTE: Do not use hyphens in chain names — Hyperlane CLI does not support them.
# EXTERNAL_L1_CHAIN_NAME=

# Optional: Private key for signing (needed for WITH=bridge contract deployment)
# EXTERNAL_L1_KEY=0x...
