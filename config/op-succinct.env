# OP Succinct Configuration
# For local development with mock prover

# Prover mode - mock for local dev, network for production
SP1_PROVER=mock

# L1 Configuration (Anvil)
L1_RPC_URL=http://l1:8545
L1_CHAIN_ID=1

# L2 Configuration (op-reth)
L2_RPC_URL=http://l2-reth:8545
L2_NODE_URL=http://l2-reth:8545
L2_CHAIN_ID=42069

# Database
DATABASE_URL=postgres://op-succinct@op-succinct-db:5432/op-succinct

# Contract Addresses (set after deployment)
# L2_OUTPUT_ORACLE_ADDRESS=0x...
# OPTIMISM_PORTAL_ADDRESS=0x...

# Proposer Configuration
PROPOSAL_INTERVAL_SECONDS=120
FINALIZATION_PERIOD_SECONDS=2

# Logging
RUST_LOG=info
