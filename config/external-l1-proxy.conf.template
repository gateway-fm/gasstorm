# Nginx reverse proxy: forwards http://l1:8545 to an external L1 RPC
# Environment variable EXTERNAL_L1_RPC is substituted at container startup

resolver 127.0.0.11 valid=10s;

server {
    listen 8545;

    location / {
        proxy_pass ${EXTERNAL_L1_RPC};
        proxy_http_version 1.1;
        proxy_set_header Content-Type application/json;
        proxy_set_header Host $proxy_host;
        proxy_connect_timeout 10s;
        proxy_read_timeout 30s;
    }
}
